# Slack (free Developer Program sandbox; Socket Mode needs no public URL)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# The reasoning model. Set EITHER one -- LabSignal picks whichever key is present.
# The MCP server is the model's only source of tools either way, so the required
# technology does not depend on which of these you use.
XAI_API_KEY=xai-your-key            # https://console.x.ai
# ANTHROPIC_API_KEY=sk-ant-your-key # https://console.anthropic.com

# Optional
# LABSIGNAL_PROVIDER=xai            # force a provider when both keys are set
# LABSIGNAL_MODEL=grok-4.3          # default: grok-4.3 (xai) / claude-opus-4-8 (anthropic)
LABSIGNAL_FORCE_LOCAL=0             # 1 disables the model + MCP entirely (keyword fallback)
