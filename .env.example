# Slack (free Developer Program sandbox; Socket Mode needs no public URL)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic. Without this, LabSignal falls back to the deterministic keyword
# router: it still answers, but Claude and MCP tool-selection are disabled.
ANTHROPIC_API_KEY=sk-ant-your-key

# Optional
LABSIGNAL_MODEL=claude-opus-4-8
LABSIGNAL_FORCE_LOCAL=0
